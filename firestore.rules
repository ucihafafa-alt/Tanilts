rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    function hasNewMembers(data) {
      return ('memberUids' in data)
        && data.memberUids is list
        && request.auth.uid in data.memberUids;
    }

    function hasLegacyMembers(data) {
      return ('members' in data)
        && data.members is list
        && request.auth.uid in data.members;
    }

    function isChatMemberData(data) {
      return signedIn() && (hasNewMembers(data) || hasLegacyMembers(data));
    }

    function parentChat(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data;
    }

    function isParentChatMember(chatId) {
      return isChatMemberData(parentChat(chatId));
    }

    function validManagedProfile(profileId) {
      return profileId is string
        && exists(/databases/$(database)/documents/managedProfiles/$(profileId))
        && get(/databases/$(database)/documents/managedProfiles/$(profileId)).data.active == true;
    }

    function validNewMemberChat() {
      return request.resource.data.mode == 'member'
        && ('memberUids' in request.resource.data)
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 2
        && request.resource.data.memberUids[0] != request.resource.data.memberUids[1]
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.updatedAt is timestamp;
    }

    function validLegacyMemberChat() {
      return ('members' in request.resource.data)
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.resource.data.members[0] != request.resource.data.members[1]
        && request.auth.uid in request.resource.data.members
        && request.resource.data.updatedAt is timestamp;
    }

    function validManagedChat() {
      return request.resource.data.mode == 'managed'
        && ('memberUids' in request.resource.data)
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 1
        && request.resource.data.memberUids[0] == request.auth.uid
        && validManagedProfile(request.resource.data.managedProfileId)
        && request.resource.data.updatedAt is timestamp;
    }

    function adminCanReadManaged(data) {
      return isAdmin()
        && ('mode' in data)
        && data.mode == 'managed';
    }

    function validPlan(planId, price) {
      return (planId == 'basic1' && price == 20000)
        || (planId == 'basic6' && price == 100000)
        || (planId == 'basic12' && price == 180000)
        || (planId == 'deep1' && price == 40000)
        || (planId == 'deep6' && price == 200000)
        || (planId == 'deep12' && price == 360000);
    }

    match /users/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.phone is string
        && request.resource.data.phone.size() == 8
        && request.resource.data.membershipUntil == 0
        && request.resource.data.premium == false;

      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());

      allow update: if isAdmin() || (
        signedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'age', 'gender', 'city', 'job', 'goal', 'bio', 'photo', 'status', 'updatedAt'
        ])
      );

      allow delete: if false;
    }

    match /publicProfiles/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'age', 'gender', 'city', 'job', 'goal', 'bio', 'photo', 'status', 'updatedAt'
        ]);
      allow delete: if false;
    }

    match /managedProfiles/{profileId} {
      allow read: if signedIn() && (resource.data.active == true || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /likes/{likeId} {
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && likeId == request.auth.uid + '_' + request.resource.data.toUid
        && request.resource.data.createdAt is timestamp;

      // Missing like documents may be checked before creation.
      allow get: if signedIn()
        && !exists(/databases/$(database)/documents/likes/$(likeId));
      allow get: if signedIn()
        && ('fromUid' in resource.data)
        && resource.data.fromUid == request.auth.uid;
      allow list: if false;
      allow delete: if signedIn()
        && ('fromUid' in resource.data)
        && resource.data.fromUid == request.auth.uid;
      allow update: if false;
    }

    match /chats/{chatId} {
      function hasNewMembers(data) {
        return data.keys().hasAny(['memberUids'])
          && data.memberUids is list
          && request.auth.uid in data.memberUids;
      }

      function hasOldMembers(data) {
        return data.keys().hasAny(['members'])
          && data.members is list
          && request.auth.uid in data.members;
      }

      function isMember(data) {
        return signedIn() && (hasNewMembers(data) || hasOldMembers(data));
      }

      function isManaged(data) {
        return data.keys().hasAny(['mode']) && data.mode == 'managed';
      }

      function sameParticipants() {
        return (
          resource.data.keys().hasAny(['memberUids'])
          && request.resource.data.keys().hasAny(['memberUids'])
          && request.resource.data.memberUids == resource.data.memberUids
        ) || (
          resource.data.keys().hasAny(['members'])
          && request.resource.data.keys().hasAny(['members'])
          && request.resource.data.members == resource.data.members
        );
      }

      // V6.2: шинэ чатанд зөвхөн нэвтэрсэн хэрэглэгч өөрөө оролцогч байх ёстой.
      // createdAt/updatedAt-ийн төрөл дээр хатуу шалгалт хийхгүй тул serverTimestamp
      // болон өмнөх cache-тай хувилбаруудын аль аль нь ажиллана.
      allow create: if signedIn()
        && isMember(request.resource.data)
        && (
          (request.resource.data.keys().hasAny(['memberUids'])
            && request.resource.data.memberUids.size() >= 1
            && request.resource.data.memberUids.size() <= 2)
          ||
          (request.resource.data.keys().hasAny(['members'])
            && request.resource.data.members.size() == 2)
        );

      allow get, list: if isMember(resource.data)
        || (isAdmin() && isManaged(resource.data));

      // Оролцогчдын жагсаалтыг сольж болохгүй; зөвхөн чатны metadata шинэчилнэ.
      allow update: if (
          isMember(resource.data)
          && isMember(request.resource.data)
          && sameParticipants()
        ) || (isAdmin() && isManaged(resource.data));

      allow delete: if false;

      match /messages/{messageId} {
        function parentData() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }

        allow read: if isMember(parentData())
          || (isAdmin() && isManaged(parentData()));

        allow create: if signedIn()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && (
            (
              isMember(parentData())
              && request.resource.data.senderUid == request.auth.uid
            )
            ||
            (
              isAdmin()
              && isManaged(parentData())
              && request.resource.data.senderType == 'managed_profile'
              && request.resource.data.senderProfileId == parentData().managedProfileId
            )
          );

        allow update, delete: if false;
      }
    }

    match /paymentRequests/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phone is string
        && request.resource.data.phone.size() == 8
        && request.resource.data.status == 'pending'
        && validPlan(request.resource.data.planId, request.resource.data.price)
        && request.resource.data.createdAt is timestamp;
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /pinResetRequests/{id} {
      allow create: if request.resource.data.keys().hasOnly(['phone', 'status', 'createdAt'])
        && request.resource.data.phone is string
        && request.resource.data.phone.size() == 8
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
