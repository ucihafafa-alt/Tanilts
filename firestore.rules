rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }
    function isMember(data) {
      return signedIn() && request.auth.uid in data.members;
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if false;
    }

    match /publicProfiles/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /likes/{likeId} {
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow read, delete: if signedIn() && resource.data.fromUid == request.auth.uid;
      allow update: if false;
    }

    match /chats/{chatId} {
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow read, update: if isMember(resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if signedIn() &&
          request.resource.data.senderUid == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow update, delete: if false;
      }
    }

    match /paymentRequests/{id} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /pinResetRequests/{id} {
      allow create: if signedIn() || request.resource.data.phone is string;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
